# Pexels — free API key from https://www.pexels.com/api/
PEXELS_API_KEY=

# ElevenLabs — optional premium TTS, free tier 10K chars/mo
# https://elevenlabs.io
ELEVENLABS_API_KEY=

# YouTube Data API v3 — Google Cloud Console (free)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# TTS engine: "google" (free) or "elevenlabs" (premium)
TTS_ENGINE=google

# ElevenLabs voice ID (only if using elevenlabs engine)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
